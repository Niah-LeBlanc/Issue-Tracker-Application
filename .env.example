# MongoDB connection string (from MongoDB Atlas or local instance)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
# Name of your MongoDB database
MONGO_DB_NAME=issue_tracker

# URL the backend is reachable at (used by better-auth for cookies/CSRF)
BETTER_AUTH_URL=http://localhost:5000

# Long random secret for signing sessions — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace_with_a_long_random_secret

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# Server port (defaults to 5000)
PORT=5000

# Set to 'production' when deploying
NODE_ENV=development
